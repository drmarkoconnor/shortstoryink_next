# Public Supabase settings used in browser + server components
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public app URL used for outbound emails and auth redirects
NEXT_PUBLIC_APP_URL=https://shortstory.ink

# Server-side app URL fallback for email/link generation
APP_URL=https://shortstory.ink

# Server-only settings for privileged operations (not used directly in Phase 1 UI)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# Auth redirect base for production links
AUTH_REDIRECT_BASE_URL=https://shortstory.ink
NEXT_PUBLIC_AUTH_REDIRECT_BASE_URL=https://shortstory.ink

# Email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=
FEEDBACK_EMAIL_FROM=
